{
  "_meta": {
    "contract": "filigree-loom",
    "stability": "Frozen for the loom-generation lifetime per ADR-002.",
    "authority": [
      "docs/architecture/decisions/ADR-002-api-generations-and-federation-posture.md"
    ],
    "pinning_discipline": "shape reference; see docs/federation/contracts.md",
    "updated": "2026-04-26",
    "endpoint": "GET /api/loom/changes",
    "status": "live as of Phase C4.",
    "relation_to_classic": "Classic /api/activity (analytics) returns events; loom /api/changes mirrors MCP's get_changes semantics. event_id replaces id at the entity primary-key level. Cursor is the 'since' timestamp; offset is not exposed."
  },
  "shape_decl": {
    "request_type": "GET; query params: since (required ISO timestamp), limit (default 100)",
    "response_type": "ListResponse[ChangeRecordLoom]",
    "rationale": "ChangeRecordLoom = IssueEventLoom + issue_title (matches EventRecordWithTitle)."
  },
  "examples": [
    {
      "name": "missing_since",
      "note": "since is required.",
      "request": {
        "method": "GET",
        "path": "/api/loom/changes",
        "headers": {},
        "body": null
      },
      "response": {
        "status": 400,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": "since query parameter is required", "code": "VALIDATION"}
      }
    },
    {
      "name": "invalid_timestamp",
      "note": "since must be ISO format.",
      "request": {
        "method": "GET",
        "path": "/api/loom/changes?since=not-a-timestamp",
        "headers": {},
        "body": null
      },
      "response": {
        "status": 400,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": "Invalid ISO timestamp: 'not-a-timestamp'. Expected format: 2026-01-15T10:30:00", "code": "VALIDATION"}
      }
    },
    {
      "name": "valid_timestamp_empty",
      "note": "Valid since with no events → empty list.",
      "request": {
        "method": "GET",
        "path": "/api/loom/changes?since=2099-01-01T00:00:00",
        "headers": {},
        "body": null
      },
      "response": {
        "status": 200,
        "headers": {"Content-Type": "application/json"},
        "body": {"items": [], "has_more": false}
      }
    }
  ]
}
