      "name": "success_empty_findings_clean_scan",
      "note": "Canonical clean-scan: no findings submitted, all counts zero, empty new_finding_ids. Pins the key set of ScanIngestResult (src/filigree/types/files.py).",
      "request": {
        "method": "POST",
        "path": "/api/v1/scan-results",
        "headers": {"Content-Type": "application/json"},
